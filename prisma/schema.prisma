generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

// ================= ENUMS =================

enum UserStatus {
    ACTIVE
    BANNED
    UNVERIFIED
}

enum DiscountType {
    PERCENT
    FIXED_AMOUNT
}

enum CouponStatus {
    ACTIVE
    EXPIRED
    DISABLED
}

enum ProductStatus {
    ACTIVE
    INACTIVE
}

enum SerialStatus {
    IN_STOCK
    SOLD
    DEFECTIVE
    IN_WARRANTY
}

enum PaymentMethod {
    COD
    VNPAY
    MOMO
    BANK_TRANSFER
}

enum PaymentStatus {
    PENDING
    PAID
    FAILED
    REFUNDED
}

enum OrderStatus {
    PENDING
    PROCESSING
    SHIPPING
    DELIVERED
    CANCELLED
}

enum ChatRoomStatus {
    OPEN
    CLOSED
}

// ================= 1. NGƯỜI DÙNG & PHÂN QUYỀN =================

model User {
    id           Int        @id @default(autoincrement())
    email        String     @unique
    passwordHash String     @map("password_hash")
    fullName     String     @map("full_name")
    phone        String?
    address      String?    @db.Text
    avatarUrl    String?    @map("avatar_url")
    status       UserStatus @default(ACTIVE)
    roleId       Int?       @map("role_id")
    createdAt    DateTime   @default(now()) @map("created_at")
    updatedAt    DateTime   @updatedAt @map("updated_at")

    role          Role?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
    cart          Cart?
    orders        Order[]
    reviews       Review[]
    chatRooms     ChatRoom[]
    messages      Message[]
    aiSavedBuilds AiSavedBuild[]

    @@map("Users")
}

model Role {
    id          Int      @id @default(autoincrement())
    name        String   @unique
    description String?  @db.Text
    createdAt   DateTime @default(now()) @map("created_at")

    users       User[]
    permissions RolePermission[]

    @@map("Roles")
}

model Permission {
    id          Int      @id @default(autoincrement())
    actionName  String   @unique @map("action_name")
    description String?  @db.Text
    createdAt   DateTime @default(now()) @map("created_at")

    roles RolePermission[]

    @@map("Permissions")
}

model RolePermission {
    roleId       Int @map("role_id")
    permissionId Int @map("permission_id")

    role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
    permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

    @@id([roleId, permissionId])
    @@map("Role_Permissions")
}

// ================= 2. THUỘC TÍNH SẢN PHẨM & ĐỐI TÁC =================

model Category {
    id          Int     @id @default(autoincrement())
    name        String
    slug        String  @unique
    description String? @db.Text

    products Product[]

    @@map("Categories")
}

model Supplier {
    id            Int     @id @default(autoincrement())
    name          String
    contactPerson String? @map("contact_person")
    phone         String?
    email         String?
    address       String? @db.Text

    products Product[]
    batches  Batch[]

    @@map("Suppliers")
}

model Coupon {
    id            Int          @id @default(autoincrement())
    code          String       @unique
    discountType  DiscountType @map("discount_type")
    discountValue Decimal      @map("discount_value") @db.Decimal(15, 2)
    minOrderValue Decimal      @default(0) @map("min_order_value") @db.Decimal(15, 2)
    startDate     DateTime     @map("start_date")
    endDate       DateTime     @map("end_date")
    usageLimit    Int          @default(100) @map("usage_limit")
    usedCount     Int          @default(0) @map("used_count")
    status        CouponStatus @default(ACTIVE)
    createdAt     DateTime     @default(now()) @map("created_at")

    orders Order[]

    @@map("Coupons")
}

// ================= 3. SẢN PHẨM =================

model Product {
    id             Int           @id @default(autoincrement())
    categoryId     Int           @map("category_id")
    supplierId     Int?          @map("supplier_id")
    name           String
    slug           String        @unique
    price          Decimal       @db.Decimal(15, 2)
    warrantyMonths Int           @default(12) @map("warranty_months")
    stockQuantity  Int           @default(0) @map("stock_quantity") // <-- Sẽ trừ thẳng vào đây khi có đơn hàng
    specifications Json
    status         ProductStatus @default(ACTIVE)
    createdAt      DateTime      @default(now()) @map("created_at")
    updatedAt      DateTime      @updatedAt @map("updated_at")

    category      Category       @relation(fields: [categoryId], references: [id])
    supplier      Supplier?      @relation(fields: [supplierId], references: [id])
    detail        ProductDetail?
    images        ProductImage[]
    batches       Batch[]
    serialNumbers SerialNumber[]
    cartItems     CartItem[]
    orderItems    OrderItem[]
    reviews       Review[]
    aiBuildItems  AiBuildItem[]

    @@map("Products")
}

model ProductDetail {
    id              Int      @id @default(autoincrement())
    productId       Int      @unique @map("product_id")
    fullDescription String?  @map("full_description") @db.LongText
    inTheBox        String?  @map("in_the_box") @db.Text
    manualUrl       String?  @map("manual_url")
    warrantyPolicy  String?  @map("warranty_policy") @db.Text
    createdAt       DateTime @default(now()) @map("created_at")
    updatedAt       DateTime @updatedAt @map("updated_at")

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("Product_Details")
}

model ProductImage {
    id        Int      @id @default(autoincrement())
    productId Int      @map("product_id")
    imageUrl  String   @map("image_url")
    isPrimary Boolean  @default(false) @map("is_primary")
    sortOrder Int      @default(0) @map("sort_order")
    altText   String?  @map("alt_text")
    createdAt DateTime @default(now()) @map("created_at")

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("Product_Images")
}

// ================= 4. QUẢN LÝ KHO CƠ BẢN =================

model Warehouse {
    id          Int      @id @default(autoincrement())
    name        String
    address     String?  @db.Text
    managerName String?  @map("manager_name")
    createdAt   DateTime @default(now()) @map("created_at")

    batches Batch[]

    @@map("Warehouses")
}

model Batch {
    id          Int      @id @default(autoincrement())
    batchCode   String   @unique @map("batch_code")
    productId   Int      @map("product_id")
    warehouseId Int      @map("warehouse_id")
    supplierId  Int      @map("supplier_id")
    importPrice Decimal  @map("import_price") @db.Decimal(15, 2)
    quantity    Int
    createdAt   DateTime @default(now()) @map("created_at")

    product       Product        @relation(fields: [productId], references: [id])
    warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
    supplier      Supplier       @relation(fields: [supplierId], references: [id])
    serialNumbers SerialNumber[]

    @@map("Batches")
}

model SerialNumber {
    id          Int          @id @default(autoincrement())
    serialCode  String       @unique @map("serial_code")
    productId   Int          @map("product_id")
    batchId     Int          @map("batch_id")
    status      SerialStatus @default(IN_STOCK)
    orderItemId Int?         @map("order_item_id")
    createdAt   DateTime     @default(now()) @map("created_at")
    updatedAt   DateTime     @updatedAt @map("updated_at")

    product   Product    @relation(fields: [productId], references: [id])
    batch     Batch      @relation(fields: [batchId], references: [id])
    orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

    @@map("Serial_Numbers")
}

// ================= 5. MUA SẮM VÀ ĐƠN HÀNG =================

model Cart {
    id        Int      @id @default(autoincrement())
    userId    Int      @unique @map("user_id")
    createdAt DateTime @default(now()) @map("created_at")

    user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    cartItems CartItem[]

    @@map("Carts")
}

model CartItem {
    id        Int @id @default(autoincrement())
    cartId    Int @map("cart_id")
    productId Int @map("product_id")
    quantity  Int @default(1)

    cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("Cart_Items")
}

model Order {
    id              Int           @id @default(autoincrement())
    userId          Int           @map("user_id")
    couponId        Int?          @map("coupon_id")
    totalAmount     Decimal       @map("total_amount") @db.Decimal(15, 2)
    discountAmount  Decimal       @default(0) @map("discount_amount") @db.Decimal(15, 2)
    shippingAddress String        @map("shipping_address") @db.Text
    phoneNumber     String        @map("phone_number")
    paymentMethod   PaymentMethod @map("payment_method")
    paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
    orderStatus     OrderStatus   @default(PENDING) @map("order_status")
    createdAt       DateTime      @default(now()) @map("created_at")
    updatedAt       DateTime      @updatedAt @map("updated_at")

    user       User        @relation(fields: [userId], references: [id])
    coupon     Coupon?     @relation(fields: [couponId], references: [id])
    orderItems OrderItem[]

    @@map("Orders")
}

model OrderItem {
    id          Int     @id @default(autoincrement())
    orderId     Int     @map("order_id")
    productId   Int     @map("product_id")
    quantity    Int
    priceAtTime Decimal @map("price_at_time") @db.Decimal(15, 2)

    order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
    product       Product        @relation(fields: [productId], references: [id])
    serialNumbers SerialNumber[]

    @@map("Order_Items")
}

// ================= 6. TƯƠNG TÁC VÀ CHĂM SÓC KHÁCH HÀNG =================

model Review {
    id        Int      @id @default(autoincrement())
    userId    Int      @map("user_id")
    productId Int      @map("product_id")
    rating    Int
    comment   String?  @db.Text
    createdAt DateTime @default(now()) @map("created_at")

    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("Reviews")
}

model ChatRoom {
    id        Int            @id @default(autoincrement())
    userId    Int            @map("user_id")
    status    ChatRoomStatus @default(OPEN)
    createdAt DateTime       @default(now()) @map("created_at")
    updatedAt DateTime       @updatedAt @map("updated_at")

    user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    messages Message[]

    @@map("Chat_Rooms")
}

model Message {
    id        Int      @id @default(autoincrement())
    roomId    Int      @map("room_id")
    senderId  Int      @map("sender_id")
    content   String   @db.Text
    createdAt DateTime @default(now()) @map("created_at")

    room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
    sender User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

    @@map("Messages")
}

// ================= 7. AI TƯ VẤN CẤU HÌNH =================

model AiSavedBuild {
    id         Int      @id @default(autoincrement())
    userId     Int      @map("user_id")
    buildName  String   @map("build_name")
    totalPrice Decimal  @map("total_price") @db.Decimal(15, 2)
    promptUsed String?  @map("prompt_used") @db.Text
    createdAt  DateTime @default(now()) @map("created_at")

    user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    aiBuildItems AiBuildItem[]

    @@map("AI_Saved_Builds")
}

model AiBuildItem {
    id          Int     @id @default(autoincrement())
    buildId     Int     @map("build_id")
    productId   Int     @map("product_id")
    quantity    Int     @default(1)
    priceAtTime Decimal @map("price_at_time") @db.Decimal(15, 2)

    build   AiSavedBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
    product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("AI_Build_Items")
}

model EmailVerification {
    id         Int      @id @default(autoincrement())
    email      String
    otp        String
    expiredAt  DateTime @map("expired_at")
    createdAt  DateTime @default(now()) @map("created_at")

    @@map("Email_Verifications")
}